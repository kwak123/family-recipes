# Firebase Admin SDK Configuration
# Get these values from your Firebase Console > Project Settings > Service Accounts

# Your Firebase Project ID (e.g., "my-family-recipes")
FIREBASE_PROJECT_ID=your-project-id

# Service Account Email (e.g., "firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com")
FIREBASE_CLIENT_EMAIL=your-service-account-email

# Service Account Private Key
# IMPORTANT: This is a multi-line key. In .env.local, keep it on one line with \n for newlines.
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEvQIBA...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google OAuth (existing)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth (existing)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Gemini AI (existing)
GEMINI_API_KEY=your-gemini-api-key
